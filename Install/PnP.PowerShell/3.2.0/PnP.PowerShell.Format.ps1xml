      </ViewSelectedBy>
      <ListControl>
        <ListEntries>
          <ListEntry>
            <ListItems>
              <ListItem>
                <PropertyName>Title</PropertyName>
              </ListItem>
              <ListItem>
                <PropertyName>Id</PropertyName>
              </ListItem>
              <ListItem>
                <PropertyName>BucketId</PropertyName>
              </ListItem>
              <ListItem>
                <PropertyName>AssigneePriority</PropertyName>
              </ListItem>
              <ListItem>
                <PropertyName>PercentComplete</PropertyName>
              </ListItem>
              <ListItem>
                <PropertyName>StartDateTime</PropertyName>
              </ListItem>
              <ListItem>
                <PropertyName>CreatedDateTime</PropertyName>
              </ListItem>
              <ListItem>
                <PropertyName>DueDateTime</PropertyName>
              </ListItem>
              <ListItem>
                <PropertyName>CompletedDateTime</PropertyName>
              </ListItem>
              <ListItem>
                <PropertyName>HasDescription</PropertyName>
              </ListItem>
              <ListItem>
                <PropertyName>PreviewType</PropertyName>
              </ListItem>
              <ListItem>
                <Label>CreatedBy</Label>
                <ScriptBlock>
                  if($_.CreatedBy.User.DisplayName -ne $null) { $_.CreatedBy.User.DisplayName } else { $_.CreatedBy.User.Id }
                </ScriptBlock>
              </ListItem>
              <ListItem>
                <Label>AppliedCategories</Label>
                <ScriptBlock>
                  $categories = [System.Collections.ArrayList]::new()
                  if($_.AppliedCategories.Category1 -ne $null ) { [void]$categories.Add("Category1") } 
                  if($_.AppliedCategories.Category2 -ne $null ) { [void]$categories.Add("Category2") } 
                  if($_.AppliedCategories.Category3 -ne $null ) { [void]$categories.Add("Category3") } 
                  if($_.AppliedCategories.Category4 -ne $null ) { [void]$categories.Add("Category4") } 
                  if($_.AppliedCategories.Category5 -ne $null ) { [void]$categories.Add("Category5") } 
                  if($_.AppliedCategories.Category6 -ne $null ) { [void]$categories.Add("Category6") } 
                  $categories
                </ScriptBlock>
              </ListItem>
              <ListItem>
                <PropertyName>Assignments</PropertyName>
              </ListItem>
            </ListItems>
          </ListEntry>
        </ListEntries>
      </ListControl>
    </View>
