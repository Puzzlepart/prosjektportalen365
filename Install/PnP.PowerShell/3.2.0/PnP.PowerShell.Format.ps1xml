          <TableRowEntry>
            <TableColumnItems>
              <TableColumnItem>
                <ScriptBlock>$_.Payload.DisplayName</ScriptBlock>
              </TableColumnItem>
              <TableColumnItem>
                <ScriptBlock>if ($_.Payload.State -eq 1) { 'Yes' } else { 'No' }</ScriptBlock>
              </TableColumnItem>
              <TableColumnItem>
                <PropertyName>LogicalId</PropertyName>
              </TableColumnItem>
              <TableColumnItem>
                <ScriptBlock>if ($_.Payload.VerticalType -eq 0) { 'Built-in' } else { 'Custom' }</ScriptBlock>
              </TableColumnItem>
            </TableColumnItems>
          </TableRowEntry>
        </TableRowEntries>
      </TableControl>
    </View>
